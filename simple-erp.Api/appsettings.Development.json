{
  "Logging": {
    "LogLevel": {
      "Default": "None",
      "simple_erp.Api.Servicos.LogService": "Debug",

      "Migracoes": "Information",
      "CargaInicial": "Information",
      "simple_erp.Api.Eventos.ServicoDeProcessamentoDoOutbox": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": true,
        "SingleLine": false,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  }
}
